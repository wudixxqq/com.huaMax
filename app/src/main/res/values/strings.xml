    <string name="setting_external_broadcast_title">Allow external broadcast control</string>
    <string name="setting_external_broadcast_description">Off (default): blocks the BroadcastReceiver — no app or ADB shell can start/stop spoofing or set coordinates via intents. On: any installed app and \'adb shell am broadcast\' can drive the module (no permission check; coordinates are clamped to valid lat/lon ranges). Only enable this if you trust every app on the device or are running on a controlled (e.g., automation) device. See docs/EXTERNAL_CONTROL.md for actions and lock-down options.</string>
    <string name="setting_system_hooks_title">Enable system-level hooks</string>
    <string name="setting_system_hooks_description">Adds the Android system framework (system/android) and the phone process (com.android.phone) to the module scope so location can be spoofed at the system level. A device restart is required for changes to take effect.</string>
